# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=draftea
POSTGRES_PASSWORD=draftea
POSTGRES_DB=draftea

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Service ports
SAGA_ORCHESTRATOR_PORT=8081
PAYMENTS_PORT=8082
WALLETS_PORT=8083
CATALOG_ACCESS_PORT=8084

# Internal service URLs (used inside Docker Compose network)
CATALOG_ACCESS_URL=http://catalog-access:8084
PAYMENTS_URL=http://payments:8082

# Saga orchestrator
SAGA_TIMEOUT=30s
TIMEOUT_POLL_INTERVAL=5s
SYNC_HTTP_TIMEOUT=2s

# Payments
PROVIDER_CHARGE_TIMEOUT=500ms
ENABLE_MOCK_PROVIDER_CONTROLS=false
